# GEMINI_API_KEY: Required by the serverless /api/gemini route.
# Keep this secret on the server. In Vercel, configure it in Project Settings
# > Environment Variables and enable it for Production.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
